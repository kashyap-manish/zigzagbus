      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');\n  body {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n  }\n</style>\n\n<div class=\"min-h-screen bg-white\" data-kid=\"1\">\n  \n  <nav class=\"bg-white shadow-sm sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"max-w-6xl mx-auto px-4 py-3 flex items-center justify-between\" data-kid=\"3\">\n      <a href=\"#\" class=\"text-xl font-extrabold text-[#2887ff] flex items-center gap-2\" data-kid=\"4\">\n        <span data-kid=\"5\">🚌</span> ZigZagBus\n      </a>\n\n      \n      <ul class=\"hidden md:flex items-center gap-8\" data-kid=\"6\">\n        <li data-kid=\"7\"><a href=\"#\" class=\"font-semibold text-[#2887ff]\" data-kid=\"8\">Home</a></li>\n        <li data-kid=\"9\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"10\">Search Buses</a></li>\n        <li data-kid=\"11\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"12\">Offers</a></li>\n        <li data-kid=\"13\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"14\">My Bookings</a></li>\n        <li data-kid=\"15\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"16\">About</a></li>\n        <li data-kid=\"17\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"18\">Contact</a></li>\n      </ul>\n\n      \n      <div class=\"hidden md:flex items-center gap-3\" data-kid=\"19\">\n        <a href=\"#\" class=\"px-4 py-2 rounded-full border border-[#2887ff] text-[#2887ff] font-semibold hover:bg-[#2887ff] hover:text-white transition text-sm\" data-kid=\"20\">Login</a>\n        <a href=\"#\" class=\"px-4 py-2 rounded-full bg-[#2887ff] text-white font-semibold hover:bg-[#2476da] transition text-sm\" data-kid=\"21\">Register</a>\n      </div>\n\n      \n      <button class=\"md:hidden flex flex-col gap-1.5 p-2\" aria-label=\"Toggle menu\" data-kid=\"22\">\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"23\"></span>\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"24\"></span>\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"25\"></span>\n      </button>\n    </div>\n  </nav>\n\n  \n  <section class=\"bg-gradient-to-br from-[#2887ff] to-[#1a5fcc] text-white py-20 px-4\" data-kid=\"26\">\n    <div class=\"max-w-6xl mx-auto text-center mb-10\" data-kid=\"27\">\n      <p class=\"uppercase tracking-widest text-blue-200 font-semibold text-sm mb-3\" data-kid=\"28\">Your Journey Starts Here</p>\n      <h1 class=\"text-4xl md:text-6xl font-extrabold leading-tight mb-4\" data-kid=\"29\">\n        Where Every Bus Ride <br data-kid=\"30\">\n        <span class=\"text-yellow-300\" data-kid=\"31\">Feels Magical!</span>\n      </h1>\n      <p class=\"text-blue-100 text-lg max-w-xl mx-auto\" data-kid=\"32\">\n        Book bus tickets across India with ease. Choose your seat, travel comfortably.\n      </p>\n    </div>\n    \n    \n    <div class=\"max-w-4xl mx-auto bg-white rounded-2xl shadow-xl p-6\" data-kid=\"33\">\n      <h2 class=\"text-xl font-bold text-gray-800 mb-4\" data-kid=\"34\">Find Your Bus</h2>\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3\" data-kid=\"35\">\n        <div data-kid=\"36\">\n          <label class=\"text-xs font-semibold text-gray-500 mb-1 block\" data-kid=\"37\">FROM</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-800 bg-white focus:outline-hidden focus:border-[#2887ff]\" data-kid=\"38\">\n            <option data-kid=\"39\">Delhi</option>\n            <option data-kid=\"40\">Mumbai</option>\n            <option data-kid=\"41\">Bangalore</option>\n            <option data-kid=\"42\">Chennai</option>\n            <option data-kid=\"43\">Kolkata</option>\n          </select>\n        </div>\n        <div data-kid=\"44\">\n          <label class=\"text-xs font-semibold text-gray-500 mb-1 block\" data-kid=\"45\">TO</label>\n          <select class=\"w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-800 bg-white focus:outline-hidden focus:border-[#2887ff]\" data-kid=\"46\">\n            <option value data-kid=\"47\">Select city</option>\n            <option data-kid=\"48\">Agra</option>\n            <option data-kid=\"49\">Jaipur</option>\n            <option data-kid=\"50\">Pune</option>\n            <option data-kid=\"51\">Hyderabad</option>\n            <option data-kid=\"52\">Lucknow</option>\n          </select>\n        </div>\n        <div data-kid=\"53\">\n          <label class=\"text-xs font-semibold text-gray-500 mb-1 block\" data-kid=\"54\">DATE</label>\n          <input type=\"date\" class=\"w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-800 bg-white focus:outline-hidden focus:border-[#2887ff]\" value=\"2025-06-15\" data-kid=\"55\">\n        </div>\n        <div data-kid=\"56\">\n          <label class=\"text-xs font-semibold text-gray-500 mb-1 block\" data-kid=\"57\">PASSENGERS</label>\n          <input type=\"number\" value=\"1\" min=\"1\" class=\"w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm text-gray-800 bg-white focus:outline-hidden focus:border-[#2887ff]\" data-kid=\"58\">\n        </div>\n      </div>\n      <button class=\"mt-4 w-full bg-[#2887ff] text-white font-bold py-3 rounded-xl hover:bg-[#2476da] transition text-sm tracking-wide\" data-kid=\"59\">\n        🔍 SEARCH BUSES\n      </button>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-white py-12 px-4 border-b\" data-kid=\"60\">\n    <div class=\"max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center\" data-kid=\"61\">\n      <div data-kid=\"62\">\n        <p class=\"text-4xl font-extrabold text-[#2887ff]\" data-kid=\"63\">10+</p>\n        <p class=\"text-gray-500 text-sm mt-1\" data-kid=\"64\">Years Experience</p>\n      </div>\n      <div data-kid=\"65\">\n        <p class=\"text-4xl font-extrabold text-[#2887ff]\" data-kid=\"66\">12k+</p>\n        <p class=\"text-gray-500 text-sm mt-1\" data-kid=\"67\">Happy Travellers</p>\n      </div>\n      <div data-kid=\"68\">\n        <p class=\"text-4xl font-extrabold text-[#2887ff]\" data-kid=\"69\">500+</p>\n        <p class=\"text-gray-500 text-sm mt-1\" data-kid=\"70\">Routes Covered</p>\n      </div>\n      <div data-kid=\"71\">\n        <p class=\"text-4xl font-extrabold text-[#2887ff]\" data-kid=\"72\">4.8</p>\n        <p class=\"text-gray-500 text-sm mt-1\" data-kid=\"73\">Average Rating</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-16 px-4 bg-gray-50\" data-kid=\"74\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"75\">\n      <h2 class=\"text-3xl font-bold text-center text-gray-800 mb-2\" data-kid=\"76\">Bus Travel, the Easy Way!</h2>\n      <p class=\"text-center text-gray-500 mb-10\" data-kid=\"77\">Effortless planning for your next adventure</p>\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6\" data-kid=\"78\">\n        <div class=\"bg-white rounded-2xl p-6 shadow-xs hover:shadow-lg transition text-center\" data-kid=\"79\">\n          <div class=\"text-4xl mb-3\" data-kid=\"80\">🎟️</div>\n          <h3 class=\"font-bold text-gray-800 mb-2\" data-kid=\"81\">Easy Booking</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"82\">Book your seat in just a few clicks. No queues, no hassle.</p>\n        </div>\n        <div class=\"bg-white rounded-2xl p-6 shadow-xs hover:shadow-lg transition text-center\" data-kid=\"83\">\n          <div class=\"text-4xl mb-3\" data-kid=\"84\">💺</div>\n          <h3 class=\"font-bold text-gray-800 mb-2\" data-kid=\"85\">Choose Your Seat</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"86\">Pick the exact seat you want with our interactive seat map.</p>\n        </div>\n        <div class=\"bg-white rounded-2xl p-6 shadow-xs hover:shadow-lg transition text-center\" data-kid=\"87\">\n          <div class=\"text-4xl mb-3\" data-kid=\"88\">🛡️</div>\n          <h3 class=\"font-bold text-gray-800 mb-2\" data-kid=\"89\">Safe & Reliable</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"90\">Verified operators and secure payments for every journey.</p>\n        </div>\n        <div class=\"bg-white rounded-2xl p-6 shadow-xs hover:shadow-lg transition text-center\" data-kid=\"91\">\n          <div class=\"text-4xl mb-3\" data-kid=\"92\">💰</div>\n          <h3 class=\"font-bold text-gray-800 mb-2\" data-kid=\"93\">Best Prices</h3>\n          <p class=\"text-gray-500 text-sm\" data-kid=\"94\">Compare operators and find the best deal for your trip.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-16 px-4 bg-white\" data-kid=\"95\">\n    <div class=\"max-w-6xl mx-auto\" data-kid=\"96\">\n      <h2 class=\"text-3xl font-bold text-gray-800 mb-2\" data-kid=\"97\">Popular Destinations</h2>\n      <p class=\"text-gray-500 mb-10\" data-kid=\"98\">Discover the most loved destinations across India</p>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"99\">\n        <div class=\"rounded-2xl overflow-hidden shadow-xs hover:shadow-lg transition group border border-gray-100\" data-kid=\"100\">\n          <div class=\"relative overflow-hidden h-56\" data-kid=\"101\">\n            <img src=\"https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?auto=format&w=800&q=80&fit=crop\" alt=\"Badrinath Temple\" class=\"w-full h-full object-cover group-hover:scale-105 transition duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"102\">\n          </div>\n          <div class=\"p-4 flex justify-between items-start bg-white\" data-kid=\"103\">\n            <div data-kid=\"104\">\n              <h4 class=\"font-bold text-gray-800\" data-kid=\"105\">Badrinath Temple</h4>\n              <p class=\"text-gray-500 text-sm\" data-kid=\"106\">Uttarakhand, India</p>\n            </div>\n            <span class=\"bg-[#2887ff] text-white text-xs font-bold px-2 py-1 rounded-full\" data-kid=\"107\">⭐ 4.7</span>\n          </div>\n        </div>\n        <div class=\"rounded-2xl overflow-hidden shadow-xs hover:shadow-lg transition group border border-gray-100\" data-kid=\"108\">\n          <div class=\"relative overflow-hidden h-56\" data-kid=\"109\">\n            <img src=\"https://images.unsplash.com/photo-1582510003544-4d00b7f74220?auto=format&w=800&q=80&fit=crop\" alt=\"Jagannath Temple\" class=\"w-full h-full object-cover group-hover:scale-105 transition duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"110\">\n          </div>\n          <div class=\"p-4 flex justify-between items-start bg-white\" data-kid=\"111\">\n            <div data-kid=\"112\">\n              <h4 class=\"font-bold text-gray-800\" data-kid=\"113\">Jagannath Temple</h4>\n              <p class=\"text-gray-500 text-sm\" data-kid=\"114\">Puri, Odisha</p>\n            </div>\n            <span class=\"bg-[#2887ff] text-white text-xs font-bold px-2 py-1 rounded-full\" data-kid=\"115\">⭐ 4.8</span>\n          </div>\n        </div>\n        <div class=\"rounded-2xl overflow-hidden shadow-xs hover:shadow-lg transition group border border-gray-100\" data-kid=\"116\">\n          <div class=\"relative overflow-hidden h-56\" data-kid=\"117\">\n            <img src=\"https://images.unsplash.com/photo-1561361058-c24e01d5ffb7?auto=format&w=800&q=80&fit=crop\" alt=\"Varanasi Ghats\" class=\"w-full h-full object-cover group-hover:scale-105 transition duration-500\" loading=\"lazy\" decoding=\"async\" data-kid=\"118\">\n          </div>\n          <div class=\"p-4 flex justify-between items-start bg-white\" data-kid=\"119\">\n            <div data-kid=\"120\">\n              <h4 class=\"font-bold text-gray-800\" data-kid=\"121\">Varanasi Ghats</h4>\n              <p class=\"text-gray-500 text-sm\"
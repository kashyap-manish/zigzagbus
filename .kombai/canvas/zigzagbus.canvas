\" data-kid=\"89\">\n        <div class=\"flex flex-col md:flex-row gap-6\" data-kid=\"90\">\n          <div class=\"flex-1\" data-kid=\"91\">\n            <div class=\"flex flex-wrap items-center gap-3 mb-2\" data-kid=\"92\">\n              <h3 class=\"text-xl font-bold text-gray-800\" data-kid=\"93\">Royal Cruiser</h3>\n              <span class=\"text-xs bg-blue-50 text-[var(--primary)] font-bold px-3 py-1 rounded-full uppercase tracking-wide\" data-kid=\"94\">AC Seater</span>\n            </div>\n            <div class=\"flex items-center gap-1 text-yellow-400 text-sm mb-4\" data-kid=\"95\">\n              <span data-kid=\"96\">★★★★</span><span class=\"text-gray-300\" data-kid=\"97\">★</span>\n              <span class=\"text-gray-500 font-medium ml-1\" data-kid=\"98\">4.2</span>\n            </div>\n            \n            <div class=\"grid grid-cols-3 items-center gap-4 py-4 px-6 bg-gray-50 rounded-xl\" data-kid=\"99\">\n              <div class=\"text-center\" data-kid=\"100\">\n                <p class=\"text-xl font-extrabold text-gray-800\" data-kid=\"101\">08:30</p>\n                <p class=\"text-xs text-gray-500 uppercase font-semibold\" data-kid=\"102\">Delhi</p>\n              </div>\n              <div class=\"relative flex flex-col items-center\" data-kid=\"103\">\n                <span class=\"text-[10px] text-gray-400 font-bold mb-1\" data-kid=\"104\">3h 30m</span>\n                <div class=\"w-full border-t border-dashed border-gray-300\" data-kid=\"105\"></div>\n                <span class=\"absolute top-1/2 -translate-y-1/2 bg-gray-50 px-2 text-lg\" data-kid=\"106\">🚌</span>\n              </div>\n              <div class=\"text-center\" data-kid=\"107\">\n                <p class=\"text-xl font-extrabold text-gray-800\" data-kid=\"108\">12:00</p>\n                <p class=\"text-xs text-gray-500 uppercase font-semibold\" data-kid=\"109\">Agra</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"md:w-px md:bg-gray-100\" data-kid=\"110\"></div>\n\n          <div class=\"md:w-64 flex flex-col justify-between text-right\" data-kid=\"111\">\n            <div data-kid=\"112\">\n              <div class=\"text-3xl font-black text-[var(--primary)]\" data-kid=\"113\">₹320</div>\n              <p class=\"text-xs text-gray-400 font-medium\" data-kid=\"114\">per person</p>\n            </div>\n            \n            <div class=\"mt-4 md:mt-0\" data-kid=\"115\">\n              <div class=\"flex flex-wrap justify-end gap-1.5 mb-4\" data-kid=\"116\">\n                <span class=\"text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-bold uppercase\" data-kid=\"117\">Charging</span>\n                <span class=\"text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-bold uppercase\" data-kid=\"118\">Water</span>\n              </div>\n              <div class=\"flex items-center justify-between gap-4\" data-kid=\"119\">\n                <p class=\"text-xs font-bold text-green-600\" data-kid=\"120\">33 seats left</p>\n                <button class=\"bg-[var(--primary)] text-white px-6 py-2.5 rounded-full font-bold hover:bg-[var(--primary-dark)] shadow-sm hover:shadow-md transition text-sm\" data-kid=\"121\">\n                  Select Seats\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white rounded-2xl shadow-xs border border-gray-100 p-6 hover:shadow-lg transition-all duration-300 opacity-90\" data-kid=\"122\">\n        <div class=\"flex flex-col md:flex-row gap-6\" data-kid=\"123\">\n          <div class=\"flex-1\" data-kid=\"124\">\n            <div class=\"flex flex-wrap items-center gap-3 mb-2\" data-kid=\"125\">\n              <h3 class=\"text-xl font-bold text-gray-800\" data-kid=\"126\">Greenline Express</h3>\n              <span class=\"text-xs bg-gray-100 text-gray-500 font-bold px-3 py-1 rounded-full uppercase tracking-wide\" data-kid=\"127\">Non-AC Seater</span>\n            </div>\n            <div class=\"flex items-center gap-1 text-yellow-400 text-sm mb-4\" data-kid=\"128\">\n              <span data-kid=\"129\">★★★</span><span class=\"text-gray-300\" data-kid=\"130\">★★</span>\n              <span class=\"text-gray-500 font-medium ml-1\" data-kid=\"131\">3.8</span>\n            </div>\n            \n            <div class=\"grid grid-cols-3 items-center gap-4 py-4 px-6 bg-gray-50 rounded-xl\" data-kid=\"132\">\n              <div class=\"text-center\" data-kid=\"133\">\n                <p class=\"text-xl font-extrabold text-gray-800\" data-kid=\"134\">10:00</p>\n                <p class=\"text-xs text-gray-500 uppercase font-semibold\" data-kid=\"135\">Delhi</p>\n              </div>\n              <div class=\"relative flex flex-col items-center\" data-kid=\"136\">\n                <span class=\"text-[10px] text-gray-400 font-bold mb-1\" data-kid=\"137\">4h 30m</span>\n                <div class=\"w-full border-t border-dashed border-gray-300\" data-kid=\"138\"></div>\n                <span class=\"absolute top-1/2 -translate-y-1/2 bg-gray-50 px-2 text-lg\" data-kid=\"139\">🚌</span>\n              </div>\n              <div class=\"text-center\" data-kid=\"140\">\n                <p class=\"text-xl font-extrabold text-gray-800\" data-kid=\"141\">14:30</p>\n                <p class=\"text-xs text-gray-500 uppercase font-semibold\" data-kid=\"142\">Agra</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"md:w-px md:bg-gray-100\" data-kid=\"143\"></div>\n\n          <div class=\"md:w-64 flex flex-col justify-between text-right\" data-kid=\"144\">\n            <div data-kid=\"145\">\n              <div class=\"text-3xl font-black text-gray-800\" data-kid=\"146\">₹200</div>\n              <p class=\"text-xs text-gray-400 font-medium\" data-kid=\"147\">per person</p>\n            </div>\n            \n            <div class=\"mt-4 md:mt-0\" data-kid=\"148\">\n              <div class=\"flex flex-wrap justify-end gap-1.5 mb-4\" data-kid=\"149\">\n                <span class=\"text-[10px] bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-bold uppercase\" data-kid=\"150\">Water</span>\n              </div>\n              <div class=\"flex items-center justify-between gap-4\" data-kid=\"151\">\n                <p class=\"text-xs font-bold text-green-600\" data-kid=\"152\">36 seats left</p>\n                <button class=\"bg-[var(--primary)] text-white px-6 py-2.5 rounded-full font-bold hover:bg-[var(--primary-dark)] shadow-sm hover:shadow-md transition text-sm\" data-kid=\"153\">\n                  Select Seats\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <footer class=\"bg-gray-900 text-gray-300 pt-16 pb-8 mt-16\" data-kid=\"154\">\n    <div class=\"max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"155\">\n      <div class=\"col-span-1\" data-kid=\"156\">\n        <h2 class=\"text-2xl font-black text-white mb-6\" data-kid=\"157\">🚌 ZigZagBus</h2>\n        <p class=\"text-sm leading-relaxed text-gray-400\" data-kid=\"158\">Your trusted bus travel partner. Book tickets, choose seats, and travel comfortably across India.</p>\n        <div class=\"flex gap-4 mt-8\" data-kid=\"159\">\n          <a href=\"#\" class=\"bg-[var(--primary)] w-10 h-10 rounded-full flex items-center justify-center hover:bg-[var(--primary-dark)] transition\" data-kid=\"160\">📘</a>\n          <a href=\"#\" class=\"bg-[var(--primary)] w-10 h-10 rounded-full flex items-center justify-center hover:bg-[var(--primary-dark)] transition\" data-kid=\"161\">📸</a>\n          <a href=\"#\" class=\"bg-[var(--primary)] w-10 h-10 rounded-full flex items-center justify-center hover:bg-[var(--primary-dark)] transition\" data-kid=\"162\">▶️</a>\n        </div>\n      </div>\n\n      <div data-kid=\"163\">\n        <h4 class=\"text-white font-bold mb-6 text-sm uppercase tracking-wider\" data-kid=\"164\">Quick Links</h4>\n        <ul class=\"space-y-3 text-sm\" data-kid=\"165\">\n          <li data-kid=\"166\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"167\">Home</a></li>\n          <li data-kid=\"168\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"169\">Search Buses</a></li>\n          <li data-kid=\"170\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"171\">Offers</a></li>\n          <li data-kid=\"172\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"173\">My Bookings</a></li>\n          <li data-kid=\"174\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"175\">About Us</a></li>\n          <li data-kid=\"176\"><a href=\"#\" class=\"hover:text-[var(--primary)] transition\" data-kid=\"177\">Contact</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"178\">\n        <h4 class=\"text-white font-bold mb-6 text-sm uppercase tracking-wider\" data-kid=\"179\">Contact</h4>\n        <ul class=\"space-y-4 text-sm\" data-kid=\"180\">\n          <li class=\"flex items-center gap-3\" data-kid=\"181\"><span data-kid=\"182\">📞</span> +91 12345 67890</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"183\"><span data-kid=\"184\">✉️</span> info@zigzagbus.in</li>\n          <li class=\"flex items-center gap-3\" data-kid=\"185\"><span data-kid=\"186\">📍</span> Agra, India</li>\n        </ul>\n      </div>\n\n      <div data-kid=\"187\">\n        <h4 class=\"text-white font-bold mb-6 text-sm uppercase tracking-wider\" data-kid=\"188\">Newsletter</h4>\n        <form class=\"flex flex-col gap-3\" data-kid=\"189\">\n          <input type=\"email\" placeholder=\"Your email address\" class=\"px-4 py-3 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white placeholder-gray-500 focus:outline-hidden focus:border-[var(--primary)] transition-all\" data-kid=\"190\">\n          <button class=\"bg-[var(--primary)] text-white py-3 rounded-lg font-bold hover:bg-[var(--primary-dark)] transition shadow-lg\" data-kid=\"191\">Subscribe</button>\n        </form>\n      </div>\n    </div>\n\n    <div class=\"text-center text-xs text-gray-600 mt-16 pt-8 border-t border-gray-800\" data-kid=\"192\">\n      © 2025 ZigZagBus. All rights reserved.\n    </div>\n  </footer>\n</div>",

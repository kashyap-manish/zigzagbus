      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n  \n  :root {\n    --primary: #2887ff;\n    --primary-dark: #2476da;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    background-color: #f9fafb;\n    color: #1f2937;\n  }\n</style>\n\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"bg-white shadow-md sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"max-w-6xl mx-auto px-4 py-3 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"text-xl font-extrabold text-[var(--primary)] flex items-center gap-2\" data-kid=\"4\">\n        <span data-kid=\"5\">🚌</span> ZigZagBus\n      </div>\n\n      <ul class=\"hidden md:flex items-center gap-8\" data-kid=\"6\">\n        <li data-kid=\"7\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[var(--primary)] transition\" data-kid=\"8\">Home</a></li>\n        <li data-kid=\"9\"><a href=\"#\" class=\"font-semibold text-[var(--primary)] transition\" data-kid=\"10\">Search Buses</a></li>\n        <li data-kid=\"11\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[var(--primary)] transition\" data-kid=\"12\">Offers</a></li>\n        <li data-kid=\"13\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[var(--primary)] transition\" data-kid=\"14\">My Bookings</a></li>\n        <li data-kid=\"15\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[var(--primary)] transition\" data-kid=\"16\">About</a></li>\n        <li data-kid=\"17\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[var(--primary)] transition\" data-kid=\"18\">Contact</a></li>\n      </ul>\n\n      <div class=\"hidden md:flex items-center gap-3\" data-kid=\"19\">\n        <a href=\"#\" class=\"px-4 py-2 rounded-full border border-[var(--primary)] text-[var(--primary)] font-semibold hover:bg-[var(--primary)] hover:text-white transition text-sm\" data-kid=\"20\">\n          Login\n        </a>\n        <a href=\"#\" class=\"px-4 py-2 rounded-full bg-[var(--primary)] text-white font-semibold hover:bg-[var(--primary-dark)] transition text-sm\" data-kid=\"21\">\n          Register\n        </a>\n      </div>\n    </div>\n  </nav>\n\n  \n  <div class=\"bg-[var(--primary)] py-6 px-4\" data-kid=\"22\">\n    <div class=\"max-w-4xl mx-auto\" data-kid=\"23\">\n      <div class=\"bg-white rounded-xl shadow-lg p-2 sm:p-3 flex flex-col sm:flex-row items-center gap-2\" data-kid=\"24\">\n        <div class=\"flex-1 w-full relative\" data-kid=\"25\">\n          <span class=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"26\">📍</span>\n          <input type=\"text\" value=\"Delhi\" readonly class=\"w-full pl-9 pr-3 py-2.5 bg-gray-50 border border-gray-100 rounded-lg text-sm font-medium focus:outline-hidden\" data-kid=\"27\">\n        </div>\n        <div class=\"text-gray-400 font-bold hidden sm:block\" data-kid=\"28\">⇄</div>\n        <div class=\"flex-1 w-full relative\" data-kid=\"29\">\n          <span class=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"30\">📍</span>\n          <input type=\"text\" value=\"Agra\" readonly class=\"w-full pl-9 pr-3 py-2.5 bg-gray-50 border border-gray-100 rounded-lg text-sm font-medium focus:outline-hidden\" data-kid=\"31\">\n        </div>\n        <div class=\"flex-1 w-full relative\" data-kid=\"32\">\n          <span class=\"absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"33\">📅</span>\n          <input type=\"text\" value=\"2025-06-15\" readonly class=\"w-full pl-9 pr-3 py-2.5 bg-gray-50 border border-gray-100 rounded-lg text-sm font-medium focus:outline-hidden\" data-kid=\"34\">\n        </div>\n        <button class=\"w-full sm:w-auto bg-[var(--primary)] text-white px-8 py-2.5 rounded-lg font-bold hover:bg-[var(--primary-dark)] transition text-sm\" data-kid=\"35\">\n          Modify\n        </button>\n      </div>\n    </div>\n  </div>\n\n  \n  <main class=\"max-w-5xl mx-auto px-4 py-8 flex-grow w-full\" data-kid=\"36\">\n    \n    <div class=\"mb-8\" data-kid=\"37\">\n      <h1 class=\"text-2xl font-bold text-gray-800\" data-kid=\"38\">Delhi → Agra</h1>\n      <p class=\"text-gray-500 text-sm mt-1\" data-kid=\"39\">\n        15 Jun 2025 · 1 passenger(s) · 3 buses found\n      </p>\n    </div>\n\n    \n    <div class=\"flex flex-wrap items-center justify-between gap-4 mb-8\" data-kid=\"40\">\n      <div class=\"flex flex-wrap gap-2\" data-kid=\"41\">\n        <button class=\"px-5 py-2 rounded-full text-sm font-semibold bg-[var(--primary)] text-white transition\" data-kid=\"42\">All</button>\n        <button class=\"px-5 py-2 rounded-full text-sm font-semibold bg-white text-gray-600 border border-gray-200 hover:border-[var(--primary)] transition\" data-kid=\"43\">AC Sleeper</button>\n        <button class=\"px-5 py-2 rounded-full text-sm font-semibold bg-white text-gray-600 border border-gray-200 hover:border-[var(--primary)] transition\" data-kid=\"44\">AC Seater</button>\n        <button class=\"px-5 py-2 rounded-full text-sm font-semibold bg-white text-gray-600 border border-gray-200 hover:border-[var(--primary)] transition\" data-kid=\"45\">Non-AC Seater</button>\n      </div>\n      \n      <div class=\"relative\" data-kid=\"46\">\n        <select class=\"appearance-none text-sm border border-gray-300 rounded-lg pl-4 pr-10 py-2 bg-white focus:outline-hidden focus:border-[var(--primary)]\" data-kid=\"47\">\n          <option data-kid=\"48\">Sort: Price (Low to High)</option>\n          <option data-kid=\"49\">Sort: Rating (High to Low)</option>\n          <option data-kid=\"50\">Sort: Departure Time</option>\n        </select>\n        <div class=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-500\" data-kid=\"51\">\n          <svg class=\"fill-current h-4 w-4\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 20 20\" data
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n</style>\n\n<div class=\"bg-white rounded-2xl shadow-md hover:shadow-xl transition-shadow duration-300 p-5 border border-gray-100 font-['Inter',_sans-serif] max-w-md mx-auto\" data-kid=\"1\">\n  \n  <div class=\"flex items-start justify-between gap-3 mb-3\" data-kid=\"2\">\n    <div class=\"flex-1 min-w-0\" data-kid=\"3\">\n      <div class=\"flex flex-wrap items-center gap-2 mb-1\" data-kid=\"4\">\n        <span class=\"font-bold text-gray-800 text-lg truncate\" data-kid=\"5\">Zingbus</span>\n        <span class=\"text-[10px] bg-blue-50 text-[#2887ff] font-bold px-2 py-0.5 rounded-full whitespace-nowrap uppercase tracking-wider\" data-kid=\"6\">AC Sleeper (2+1)</span>\n      </div>\n      <div class=\"flex items-center gap-1 text-yellow-500 text-sm\" data-kid=\"7\">\n        <span class=\"flex items-center\" data-kid=\"8\">\n          <svg class=\"w-3.5 h-3.5 fill-current\" viewBox=\"0 0 20 20\" data-kid=\"9\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\" data-kid=\"10\"></path></svg>\n          <svg class=\"w-3.5 h-3.5 fill-current\" viewBox=\"0 0 20 20\" data-kid=\"11\"><path d=\"M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z\" data-kid=\"12\"></path></svg>\n          <svg class=\"w-3.5 h-3.5 fill-current\" viewBox=\"0 0 20 2
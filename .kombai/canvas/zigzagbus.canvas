n\n  \n  <div class=\"flex items-center justify-between gap-4 pt-4 border-t border-gray-100\" data-kid=\"43\">\n    <div class=\"flex items-center gap-1.5\" data-kid=\"44\">\n      <div class=\"relative flex h-2 w-2\" data-kid=\"45\">\n        <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75\" data-kid=\"46\"></span>\n        <span class=\"relative inline-flex rounded-full h-2 w-2 bg-green-500\" data-kid=\"47\"></span>\n      </div>\n      <p class=\"text-xs font-bold text-green-600\" data-kid=\"48\">\n        37 seats available\n      </p>\n    </div>\n    <button class=\"bg-[#2887ff] text-white px-6 py-2.5 rounded-xl font-bold hover:bg-[#2476da] hover:shadow-lg transition-all active:scale-95 text-xs whitespace-nowrap cursor-pointer\" data-kid=\"49\">\n      Select Seats\n    </button>\n  </div>\n</div>",

      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap');\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n  }\n</style>\n\n<nav class=\"bg-white shadow-md sticky top-0 z-50 w-full\" data-kid=\"1\">\n  <div class=\"max-w-6xl mx-auto px-4 py-3 flex items-center justify-between\" data-kid=\"2\">\n    \n    <a href=\"/\" class=\"text-xl font-extrabold text-[#2887ff] flex items-center gap-2 no-underline\" data-kid=\"3\">\n      <span data-kid=\"4\">🚌</span> ZigZagBus\n    </a>\n\n    \n    <ul class=\"hidden md:flex items-center gap-8 list-none m-0 p-0\" data-kid=\"5\">\n      <li data-kid=\"6\">\n        <a href=\"/\" class=\"font-semibold text-[#2887ff] transition no-underline\" data-kid=\"7\">Home</a>\n      </li>\n      <li data-kid=\"8\">\n        <a href=\"/search\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition no-underline\" data-kid=\"9\">Search Buses</a>\n      </li>\n      <li data-kid=\"10\">\n        <a href=\"/offers\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition no-underline\" data-kid=\"11\">Offers</a>\n      </li>\n      <li data-kid=\"12\">\n        <a href=\"/bookings\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition no-underline\" data-kid=\"13\">My Bookings</a>\n      </li>\n      <li data-kid=\"14\">\n        <a href=\"/about\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition no-underline\" data-kid=\"15\">About</a>\n      </li>\n      <li data-kid=\"16\">\n        <a href=\"/contact\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition no-underline\" data-kid=\"17\">Contact</a>\n      </li>\n    </ul>\n\n    \n    <div class=\"hidden md:flex items-center gap-3\" data-kid=\"18\">\n      <a href=\"/login\" class=\"px-5 py-2 rounded-full border border-[#2887ff] text-[#2887ff] font-semibold hover:bg-[#2887ff] hover:text-white transition text-sm no-underline text-center min-w-[80px]\" data-kid=\"19\">\n        Login\n      </a>\n      <a href=\"/register\" class=\"px-5 py-2 rounded-full bg-[#2887ff] text-white font-semibold hover:bg-[#2476da] transition text-sm no-underline text-center min-w-[100px]\" data-kid=\"20\">\n        Register\n      </a>\n    </div>\n\n    \n    <button class=\"md:hidden flex flex-col gap-1.5 p-2 bg-transparent border-none cursor-pointer outline-none\" aria-label=\"Toggle menu\" data-kid=\"21\">\n      <span class=\"block w-6 h-0.5 bg-[#2887ff] rounded-full\" data-kid=\"22\"></span>\n      <span class=\"block w-6 h-0.5 bg-[#2887ff] rounded-full\" data-kid=\"23\"></span>\n      <span class=\"block w-6 h-0.5 bg-[#2887ff] rounded-full\" data-kid=\"24\"></span>\n    </button>\n  </div>\n</nav>",

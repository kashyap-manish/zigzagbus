      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n  }\n</style>\n\n<div class=\"min-h-screen bg-gray-50 flex flex-col\" data-kid=\"1\">\n  \n  <nav class=\"bg-white shadow-sm sticky top-0 z-50\" data-kid=\"2\">\n    <div class=\"max-w-6xl mx-auto px-4 py-3 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"text-xl font-extrabold text-[#2887ff] flex items-center gap-2\" data-kid=\"4\">\n        <span data-kid=\"5\">🚌</span> ZigZagBus\n      </div>\n\n      \n      <ul class=\"hidden md:flex items-center gap-8\" data-kid=\"6\">\n        <li data-kid=\"7\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"8\">Home</a></li>\n        <li data-kid=\"9\"><a href=\"#\" class=\"font-semibold text-[#2887ff] transition\" data-kid=\"10\">Search Buses</a></li>\n        <li data-kid=\"11\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"12\">Offers</a></li>\n        <li data-kid=\"13\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"14\">My Bookings</a></li>\n        <li data-kid=\"15\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"16\">About</a></li>\n        <li data-kid=\"17\"><a href=\"#\" class=\"font-semibold text-gray-700 hover:text-[#2887ff] transition\" data-kid=\"18\">Contact</a></li>\n      </ul>\n\n      \n      <div class=\"hidden md:flex items-center gap-3\" data-kid=\"19\">\n        <span class=\"text-sm text-gray-600\" data-kid=\"20\">Hi, Rahul</span>\n        <button class=\"px-4 py-2 rounded-full border border-[#2887ff] text-[#2887ff] font-semibold hover:bg-[#2887ff] hover:text-white transition text-sm\" data-kid=\"21\">\n          Logout\n        </button>\n      </div>\n      \n      \n      <button class=\"md:hidden flex flex-col gap-1.5 p-2\" data-kid=\"22\">\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"23\"></span>\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"24\"></span>\n        <span class=\"block w-6 h-0.5 bg-[#2887ff]\" data-kid=\"25\"></span>\n      </button>\n    </div>\n  </nav>\n\n  \n  <main class=\"flex-grow py-10 px-4\" data-kid=\"26\">\n    <div class=\"max-w-3xl mx-auto\" data-kid=\"27\">\n      \n      <button class=\"text-[#2887ff] text-sm font-semibold mb-6 flex items-center gap-1 hover:underline\" data-kid=\"28\">\n        ← Back to results\n      </button>\n\n      \n      <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-5\" data-kid=\"29\">\n        <div class=\"flex justify-between items-start\" data-kid=\"30\">\n          <div data-kid=\"31\">\n            <h2 class=\"text-xl font-bold text-gray-900 mb-1\" data-kid=\"32\">Shyam Travels</h2>\n            <p class=\"text-gray-500 text-sm\" data-kid=\"33\">Delhi → Agra • 06:00 - 10:00 • AC Sleeper</p>\n          </div>\n          <div class=\"bg-blue-50 text-[#2887ff] px-3 py-1 rounded-lg text-sm font-bold\" data-kid=\"34\">\n            ₹450 / seat\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-5\" data-kid=\"35\">\n        <h3 class=\"font-bold text-gray-800 mb-6 flex items-center gap-2\" data-kid=\"36\">\n          Select Seats <span class=\"text-gray-400 font-normal text-sm\" data-kid=\"37\">(max 4)</span>\n        </h3>\n\n        \n        <div class=\"flex gap-6 mb-8 text-sm flex-wrap\" data-kid=\"38\">\n          <div class=\"flex items-center gap-2\" data-kid=\"39\">\n            <div class=\"w-5 h-5 rounded bg-gray-100 border border-gray-300\" data-kid=\"40\"></div>\n            <span class=\"text-gray-600 font-medium\" data-kid=\"41\">Available</span>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"42\">\n            <div class=\"w-5 h-5 rounded bg-[#2887ff]\" data-kid=\"43\"></div>\n            <span class=\"text-gray-600 font-medium\" data-kid=\"44\">Selected</span>\n          </div>\n          <div class=\"flex items-center gap-2\" data-kid=\"45\">\n            <div class=\"w-5 h-5 rounded bg-red-400\" data-kid=\"46\"></div>\n            <span class=\"text-gray-600 font-medium\" data-kid=\"47\">Booked</span>\n          </div>\n        </div>\n\n        \n        <div class=\"text-center text-gray-400 text-xs font-bold uppercase tracking-wider mb-6 border-b border-gray-100 pb-4\" data-kid=\"48\">\n          🚌 Front of Bus\n        </div>\n\n        \n        <div class=\"space-y-3 overflow-x-auto\" data-kid=\"49\">\n          \n          <div class=\"flex gap-3 justify-center items-center min-w-max\" data-kid=\"50\">\n            \n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"51\">1</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-red-400 text-white cursor-not-allowed\" data-kid=\"52\">2</button>\n            \n            \n            <div class=\"w-6\" data-kid=\"53\"></div>\n            \n            \n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"54\">3</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"55\">4</button>\n          </div>\n\n          <div class=\"flex gap-3 justify-center items-center min-w-max\" data-kid=\"56\">\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-red-400 text-white cursor-not-allowed\" data-kid=\"57\">5</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"58\">6</button>\n            <div class=\"w-6\" data-kid=\"59\"></div>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-[#2887ff] text-white ring-2 ring-blue-200\" data-kid=\"60\">7</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-[#2887ff] text-white ring-2 ring-blue-200\" data-kid=\"61\">8</button>\n          </div>\n\n          <div class=\"flex gap-3 justify-center items-center min-w-max\" data-kid=\"62\">\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"63\">9</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-red-400 text-white cursor-not-allowed\" data-kid=\"64\">10</button>\n            <div class=\"w-6\" data-kid=\"65\"></div>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"66\">11</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"67\">12</button>\n          </div>\n\n          <div class=\"flex gap-3 justify-center items-center min-w-max\" data-kid=\"68\">\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"69\">13</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"70\">14</button>\n            <div class=\"w-6\" data-kid=\"71\"></div>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-red-400 text-white cursor-not-allowed\" data-kid=\"72\">15</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300 hover:bg-blue-50 transition\" data-kid=\"73\">16</button>\n          </div>\n\n          \n          <div class=\"flex gap-3 justify-center items-center min-w-max opacity-60\" data-kid=\"74\">\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300\" data-kid=\"75\">17</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300\" data-kid=\"76\">18</button>\n            <div class=\"w-6\" data-kid=\"77\"></div>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300\" data-kid=\"78\">19</button>\n            <button class=\"w-10 h-10 rounded-lg text-xs font-bold bg-gray-100 text-gray-700 border border-gray-300\" data-kid=\"79\">20</button>\n          </div>\n          \n          <div class=\"text-center text-gray-300 text-[10px] italic py-2\" data-kid=\"80\">\n            ... Grid continues to 40 seats ...\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white rounded-2xl shadow-md border border-gray-100 p-6\" data-kid=\"81\">\n        <div class=\"flex flex-col sm:flex-row sm:items-center justify-between gap-6\" data-kid=\"82\">\n          <div class=\"space-y-1\" data-kid=\"83\">\n            <div class=\"flex items-center gap-2\" data-kid=\"84\">\n              <span class=\"text-sm text-gray-500 font-medium uppercase tracking-wide\" data-kid=\"85\">Selected Seats:</span>\n              <span class=\"font-bold text-gray-800 bg-blue-50 px-2 py-0.5 rounded\" data-kid=\"86\">7, 8</span>\n            </div>\n            <div class=\"flex items-baseline gap-2\" data-kid=\"87\">\n              <span class=\"text-sm text-gray-500 font-medium\" data-kid=\"88\">Total Price:</span>\n              <span class=\"text-2xl font-extrabold text-[#2887ff]\" data-kid=\"89\">₹900</span>\n            </div>\n          </div>\n          <button class=\"w-full sm:w-auto bg-[#2887ff] text-white px-10 py-4 rounded-full font-bold hover:bg-[#2476da] transition shadow-lg shadow-blue-200 active:scale-95\" data-kid=\"90\">\n            Continue to Checkout →\n          </button>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  \n  <footer class=\"bg-gray-900 text-gray-300 pt-16 pb-8\" data-kid=\"91\">\n    <div class=\"max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"92\">\n      <div class=\"col-span-1 md:col-span-1\" data-kid=\"93\">\n        <h2 class=\"text-xl font-extrabold text-white mb-4\" data-kid=\"94\">🚌 ZigZagBus</h2>\n        <p class=\"text-sm text-gray-400 leading-relaxed\" data-kid=\"95\">Your trusted bus travel partner. Book tickets, choose seats, and travel comfortably across India.</p>\n        <div class=\"flex gap-3 mt-6\" data-kid=\"96\">\n          <a href=\"#\" class=\"bg-[#2887ff] w-9 h-9 rounded-full flex items-center justify-center hover:bg-[#2476da] transition text-sm\" data-kid=\"97\">📘</a>\n          <a href=\"#\" class=\"bg-[#2887ff] w-9 h-9 rounded-full flex items-center justify-center hover:bg-[#2476da] transition text-sm\" data-kid=\"98\">📸</a>\n          <a href=\"#\" class=\"bg-[#2887ff] w-9 h-9 rounded-full flex items-center justify-center hover:bg-[#2476da] transition text-sm\" data-kid=\"99\">▶️</a>\n        </div>\n      </div>\n\n      <div data-kid=\"100\">\n        <h4 class=\"text-white font-bold mb-6\" data-kid=\"101\">Quick Links</h4>\n        <ul class=\"space-y-3 text-sm\" data-kid=\"102\">\n          <li data-kid=\"103\"><a href=\"#\" class=\"hover:text-[#2887ff] transition\" data-kid=\"104\">Search Buses</a></li>\n          <li data-kid=\"105\"><a href=\"#\" class=\"hover:text-[#2887ff] transition\" data-kid=\"106\">Offers</a></li>\n          <li data-kid=\"107\"><a href=\"#\" class=\"hover:text-[#2887ff] transition\" data-kid=\"108\">My Bookings</a></li>\n          <li data-kid=\"109\"><a href=\"#\" class=\"hover:text-[#2887ff] transition\" data-kid=\"110\">Contact Us</a></li>\n        </ul>\n      </div>\n\n      <div data-kid=\"111\">\n        <h4 class=\"text-white font-bold mb-6\" data-kid=\"112\">Contact Info</h4>\n        <ul class=\"space-y-3 text-sm\" data-kid=\"113\">\n          <li class=\"flex items-center gap-2\" data-kid=\"114\"><span data-kid=\"115\">📞</span> +91 12345 67890</li>\n          <li class=\"flex items-center gap-2\" data-kid=\"116\"><span data-kid=\"117\">✉️</span> info@zigzagbus.in</li>\n          <li class=\"flex items-center gap-2\" data-kid=\"118\"><span data-kid=\"119\">📍</span> Agra, India</li>\n        </ul>\n      </div>\n\n      <div data-kid=\"120\">\n        <h4 class=\"text-white font-bold mb-6\" data-kid=\"121\">Newsletter</h4>\n        <form class=\"flex flex-col gap-3\" data-kid=\"122\">\n          <input type=\"email\" placeholder=\"Your email address\" class=\"px-4 py-3 rounded-lg bg-gray-800 border border-gray-700 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-[#2887ff] transition\" data-kid=\"123\">\n          <button class=\"bg-[#2887ff] text-white py-3 rounded-lg font-bold hover:bg-[#2476da] transition text-sm\" data-kid=\"124\">Subscribe</button>\n        </form>\n      </div>\n    </div>\n\n    <div class=\"text-center text-xs text-gray-500 mt-16 border-t border-gray-800 pt-8\" data-kid=\"125\">\n      © 2025 ZigZagBus. All rights reserved.\n    </div>\n  </footer>\n</div>",

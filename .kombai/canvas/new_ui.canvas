      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Roboto+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n  .font-mono { font-family: 'Roboto Mono', monospace; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .outline-text {\n    -webkit-text-stroke: 1px #0f172a;\n    color: transparent;\n  }\n\n  .grid-overlay {\n    background-size: calc(100% / 12) 100%;\n    background-image: linear-gradient(to right, #f1f5f9 1px, transparent 1px);\n  }\n\n  .bw-filter {\n    filter: grayscale(100%);\n    transition: filter 0.4s ease;\n  }\n  .bw-filter:hover {\n    filter: grayscale(0%);\n  }\n</style>\n\n<div class=\"min-h-screen bg-white font-sans text-[#0f172a] selection:bg-[#2887ff] selection:text-white\" data-kid=\"1\">\n  \n  <div class=\"pointer-events-none fixed inset-0 z-0 grid-overlay opacity-50\" data-kid=\"2\"></div>\n\n  \n  <nav class=\"sticky top-0 z-50 border-b border-[#0f172a]/10 bg-white/80 backdrop-blur-md\" data-kid=\"3\">\n    <div class=\"mx-auto flex h-20 max-w-7xl items-center justify-between px-6\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2\" data-kid=\"5\">\n        <div class=\"h-8 w-8 bg-[#2887ff]\" data-kid=\"6\"></div>\n        <span class=\"font-space text-2xl font-bold tracking-tighter uppercase\" data-kid=\"7\">ZigZagBus</span>\n      </div>\n      <div class=\"hidden items-center gap-10 font-space text-sm font-medium tracking-tight md:flex\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"9\">ROUTES</a>\n        <a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"10\">OFFERS</a>\n        <a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"11\">TRACKING</a>\n        <a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"12\">SUPPORT</a>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"13\">\n        <button class=\"font-space text-sm font-bold tracking-tight\" data-kid=\"14\">LOGIN</button>\n        <button class=\"bg-[#2887ff] px-6 py-2.5 font-space text-sm font-bold tracking-tight text-white hover:bg-[#2476da]\" data-kid=\"15\">BOOK NOW</button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative z-10 mx-auto max-w-7xl px-6 pt-20 pb-32\" data-kid=\"16\">\n    <div class=\"grid grid-cols-12 gap-10\" data-kid=\"17\">\n      \n      <div class=\"col-span-12 lg:col-span-7\" data-kid=\"18\">\n        <div class=\"mb-4 inline-block bg-[#2887ff] px-3 py-1 font-mono text-xs font-bold text-white uppercase\" data-kid=\"19\">Version 4.0.1</div>\n        <h1 class=\"font-space mb-10 text-7xl font-bold leading-[0.9] tracking-tighter lg:text-8xl\" data-kid=\"20\">\n          REDESIGNING <br data-kid=\"21\">\n          <span class=\"text-[#2887ff]\" data-kid=\"22\">TRANSIT.</span>\n        </h1>\n        \n        \n        <div class=\"border border-[#0f172a] p-8\" data-kid=\"23\">\n          <div class=\"mb-6 flex items-center justify-between border-b border-[#0f172a]/10 pb-2\" data-kid=\"24\">\n            <span class=\"font-mono text-xs text-[#0f172a]/50 uppercase\" data-kid=\"25\">Search_Engine_Terminal_v1</span>\n            <div class=\"flex gap-1.5\" data-kid=\"26\">\n              <div class=\"h-2 w-2 rounded-full bg-red-400\" data-kid=\"27\"></div>\n              <div class=\"h-2 w-2 rounded-full bg-yellow-400\" data-kid=\"28\"></div>\n              <div class=\"h-2 w-2 rounded-full bg-green-400\" data-kid=\"29\"></div>\n            </div>\n          </div>\n          \n          <form class=\"grid grid-cols-1 gap-8 md:grid-cols-2\" data-kid=\"30\">\n            <div class=\"group relative\" data-kid=\"31\">\n              <label class=\"font-mono absolute -top-3 left-0 text-[10px] text-[#0f172a]/40 uppercase tracking-widest transition-all group-focus-within:text-[#2887ff]\" data-kid=\"32\">Origin</label>\n              <input type=\"text\" placeholder=\"Enter City\" class=\"w-full border-b border-[#0f172a] bg-transparent py-4 font-space text-xl font-medium outline-none focus:border-[#2887ff]\" data-kid=\"33\">\n            </div>\n            <div class=\"group relative\" data-kid=\"34\">\n              <label class=\"font-mono absolute -top-3 left-0 text-[10px] text-[#0f172a]/40 uppercase tracking-widest transition-all group-focus-within:text-[#2887ff]\" data-kid=\"35\">Destination</label>\n              <input type=\"text\" placeholder=\"Enter City\" class=\"w-full border-b border-[#0f172a] bg-transparent py-4 font-space text-xl font-medium outline-none focus:border-[#2887ff]\" data-kid=\"36\">\n            </div>\n            <div class=\"group relative\" data-kid=\"37\">\n              <label class=\"font-mono absolute -top-3 left-0 text-[10px] text-[#0f172a]/40 uppercase tracking-widest transition-all group-focus-within:text-[#2887ff]\" data-kid=\"38\">Departure_Date</label>\n              <input type=\"date\" class=\"w-full border-b border-[#0f172a] bg-transparent py-4 font-space text-xl font-medium outline-none focus:border-[#2887ff]\" data-kid=\"39\">\n            </div>\n            <div class=\"flex items-end\" data-kid=\"40\">\n              <button type=\"submit\" class=\"flex w-full items-center justify-between bg-[#0f172a] px-8 py-4 font-space font-bold text-white transition-all hover:bg-[#2887ff]\" data-kid=\"41\">\n                <span data-kid=\"42\">INITIALIZE SEARCH</span>\n                <i class=\"ti ti-arrow-narrow-right text-2xl\" data-kid=\"43\"></i>\n              </button>\n            </div>\n          </form>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-12 flex flex-col justify-center lg:col-span-5\" data-kid=\"44\">\n        <div class=\"relative overflow-hidden border-2 border-[#0f172a]\" data-kid=\"45\">\n          <div class=\"absolute top-4 left-4 z-20 flex items-center gap-2 rounded bg-black/50 px-2 py-1 backdrop-blur-sm\" data-kid=\"46\">\n            <div class=\"h-2 w-2 animate-pulse rounded-full bg-red-500\" data-kid=\"47\"></div>\n            <span class=\"font-mono text-[10px] text-white uppercase tracking-tighter\" data-kid=\"48\">Live_Feed_024</span>\n          </div>\n          <video src=\"https://videos.pexels.com/video-files/19242419/19242419-sd_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/19242419/automobile-busy-city-drive-19242419.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"aspect-square w-full object-cover opacity-90 grayscale contrast-125\" data-kid=\"49\"></video>\n        </div>\n        <div class=\"mt-4 border-l border-[#2887ff] pl-4\" data-kid=\"50\">\n          <p class=\"font-mono text-xs leading-relaxed text-[#0f172a]/60\" data-kid=\"51\">\n            Real-time highway traffic monitoring and predictive pathfinding integration for all ZigZag fleet vehicles. High-speed connectivity ensured across all zones.\n          </p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"border-y-2 border-[#0f172a] bg-[#f8fafc] py-6 overflow-hidden\" data-kid=\"52\">\n    <div class=\"flex animate-marquee whitespace-nowrap gap-20 items-center\" data-kid=\"53\">\n      <div class=\"flex items-center gap-4\" data-kid=\"54\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"55\">Trips_Completed:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"56\">248,932</span>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"57\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"58\">Active_Cities:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"59\">142</span>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"60\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"61\">Satisfaction_Rate:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"62\">99.8%</span>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"63\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"64\">Safety_Protocol:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"65\">EN-12642</span>\n      </div>\n      \n      <div class=\"flex items-center gap-4\" data-kid=\"66\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"67\">Trips_Completed:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"68\">248,932</span>\n      </div>\n      <div class=\"flex items-center gap-4\" data-kid=\"69\">\n        <span class=\"font-mono text-sm text-[#0f172a]/40 uppercase\" data-kid=\"70\">Active_Cities:</span>\n        <span class=\"font-mono text-3xl font-bold text-[#2887ff]\" data-kid=\"71\">142</span>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"mx-auto max-w-7xl px-6 py-32\" data-kid=\"72\">\n    <div class=\"mb-20\" data-kid=\"73\">\n      <h2 class=\"font-space text-5xl font-bold tracking-tighter uppercase\" data-kid=\"74\">Infrastructure.</h2>\n      <div class=\"h-1 w-20 bg-[#2887ff]\" data-kid=\"75\"></div>\n    </div>\n\n    <div class=\"border-t border-[#0f172a]\" data-kid=\"76\">\n      \n      <div class=\"group flex flex-col items-start border-b border-[#0f172a] py-10 transition-all hover:bg-[#2887ff]/5 md:flex-row md:items-center\" data-kid=\"77\">\n        <div class=\"mb-4 flex w-20 shrink-0 justify-center md:mb-0\" data-kid=\"78\">\n          <i class=\"ti ti-qrcode text-4xl text-[#2887ff]\" data-kid=\"79\"></i>\n        </div>\n        <div class=\"flex grow flex-col gap-2 px-0 md:px-10\" data-kid=\"80\">\n          <h3 class=\"font-space text-2xl font-bold uppercase\" data-kid=\"81\">Dynamic QR Ticketing</h3>\n          <p class=\"max-w-xl text-sm leading-relaxed text-[#0f172a]/60\" data-kid=\"82\">Paperless and touch-free boarding experience. Your ticket updates in real-time with platform and seat changes.</p>\n        </div>\n        <div class=\"mt-4 font-mono text-xs font-bold text-[#0f172a]/40 md:mt-0\" data-kid=\"83\">SEC_ID: QR_001</div>\n      </div>\n\n      \n      <div class=\"group flex flex-col items-start border-b border-[#0f172a] py-10 transition-all hover:bg-[#2887ff]/5 md:flex-row md:items-center\" data-kid=\"84\">\n        <div class=\"mb-4 flex w-20 shrink-0 justify-center md:mb-0\" data-kid=\"85\">\n          <i class=\"ti ti-layout-grid text-4xl text-[#2887ff]\" data-kid=\"86\"></i>\n        </div>\n        <div class=\"flex grow flex-col gap-2 px-0 md:px-10\" data-kid=\"87\">\n          <h3 class=\"font-space text-2xl font-bold uppercase\" data-kid=\"88\">Grid-based Seat Select</h3>\n          <p class=\"max-w-xl text-sm leading-relaxed text-[#0f172a]/60\" data-kid=\"89\">Precise 3D visualization of bus interiors. Select the exact seat with legroom and window specifications.</p>\n        </div>\n        <div class=\"mt-4 font-mono text-xs font-bold text-[#0f172a]/40 md:mt-0\" data-kid=\"90\">VIS_ID: GRID_12</div>\n      </div>\n\n      \n      <div class=\"group flex flex-col items-start border-b border-[#0f172a] py-10 transition-all hover:bg-[#2887ff]/5 md:flex-row md:items-center\" data-kid=\"91\">\n        <div class=\"mb-4 flex w-20 shrink-0 justify-center md:mb-0\" data-kid=\"92\">\n          <i class=\"ti ti-lock text-4xl text-[#2887ff]\" data-kid=\"93\"></i>\n        </div>\n        <div class=\"flex grow flex-col gap-2 px-0 md:px-10\" data-kid=\"94\">\n          <h3 class=\"font-space text-2xl font-bold uppercase\" data-kid=\"95\">Biometric Verification</h3>\n          <p class=\"max-w-xl text-sm leading-relaxed text-[#0f172a]/60\" data-kid=\"96\">Advanced identity verification for long-haul routes. Secure encryption of all personal passenger metadata.</p>\n        </div>\n        <div class=\"mt-4 font-mono text-xs font-bold text-[#0f172a]/40 md:mt-0\" data-kid=\"97\">AUTH_ID: BIO_X</div>\n      </div>\n\n      \n      <div class=\"group flex flex-col items-start border-b border-[#0f172a] py-10 transition-all hover:bg-[#2887ff]/5 md:flex-row md:items-center\" data-kid=\"98\">\n        <div class=\"mb-4 flex w-20 shrink-0 justify-center md:mb-0\" data-kid=\"99\">\n          <i class=\"ti ti-chart-bar text-4xl text-[#2887ff]\" data-kid=\"100\"></i>\n        </div>\n        <div class=\"flex grow flex-col gap-2 px-0 md:px-10\" data-kid=\"101\">\n          <h3 class=\"font-space text-2xl font-bold uppercase\" data-kid=\"102\">Efficiency Analytics</h3>\n          <p class=\"max-w-xl text-sm leading-relaxed text-[#0f172a]/60\" data-kid=\"103\">Optimization of routes based on high-density travel patterns. Reduced idle time for faster transit cycles.</p>\n        </div>\n        <div class=\"mt-4 font-mono text-xs font-bold text-[#0f172a]/40 md:mt-0\" data-kid=\"104\">ANL_ID: DATA_CORE</div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[#0f172a] px-6 py-32 text-white\" data-kid=\"105\">\n    <div class=\"mx-auto max-w-7xl\" data-kid=\"106\">\n      <div class=\"mb-20 flex items-end justify-between\" data-kid=\"107\">\n        <div data-kid=\"108\">\n          <h2 class=\"font-space text-5xl font-bold tracking-tighter uppercase\" data-kid=\"109\">High Speed Zones.</h2>\n          <div class=\"mt-4 h-1 w-20 bg-[#2887ff]\" data-kid=\"110\"></div>\n        </div>\n        <div class=\"font-mono text-sm text-white/40 uppercase\" data-kid=\"111\">Active_Routes_2026</div>\n      </div>\n\n      <div class=\"grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3\" data-kid=\"112\">\n        \n        <div class=\"group relative aspect-[4/5] overflow-hidden bg-slate-800\" data-kid=\"113\">\n          <img src=\"https://images.unsplash.com/photo-1563816474234-8d5f987c532a?auto=format&w=800&q=80&fit=crop\" decoding=\"async\" loading=\"lazy\" class=\"bw-filter h-full w-full object-cover\" alt=\"Modern Bridge\" data-kid=\"114\">\n          <div class=\"absolute bottom-0 left-0 bg-[#0f172a] p-4 font-space\" data-kid=\"115\">\n            <div class=\"text-xs font-bold text-[#2887ff] uppercase tracking-widest\" data-kid=\"116\">Zone_01</div>\n            <div class=\"text-2xl font-bold uppercase\" data-kid=\"117\">MUMBAI_EXPRESS</div>\n          </div>\n          <div class=\"absolute top-4 right-4 bg-[#2887ff] px-2 py-1 font-mono text-[10px] font-bold\" data-kid=\"118\">4.9 ★</div>\n        </div>\n\n        \n        <div class=\"group relative aspect-[4/5] overflow-hidden bg-slate-800\" data-kid=\"119\">\n          <img src=\"https://images.unsplash.com/photo-1599818870786-636f668088eb?auto=format&w=800&q=80&fit=crop\" decoding=\"async\" loading=\"lazy\" class=\"bw-filter h-full w-full object-cover\" alt=\"Winding Road\" data-kid=\"120\">\n          <div class=\"absolute bottom-0 left-0 bg-[#0f172a] p-4 font-space\" data-kid=\"121\">\n            <div class=\"text-xs font-bold text-[#2887ff] uppercase tracking-widest\" data-kid=\"122\">Zone_05</div>\n            <div class=\"text-2xl font-bold uppercase\" data-kid=\"123\">KERALA_COAST</div>\n          </div>\n          <div class=\"absolute top-4 right-4 bg-[#2887ff] px-2 py-1 font-mono text-[10px] font-bold\" data-kid=\"124\">4.8 ★</div>\n        </div>\n\n        \n        <div class=\"group relative aspect-[4/5] overflow-hidden bg-slate-800\" data-kid=\"125\">\n          <img src=\"https://images.unsplash.com/photo-1488972685288-c3fd157d7c7a?auto=format&w=800&q=80&fit=crop\" decoding=\"async\" loading=\"lazy\" class=\"bw-filter h-full w-full object-cover\" alt=\"Architecture\" data-kid=\"126\">\n          <div class=\"absolute bottom-0 left-0 bg-[#0f172a] p-4 font-space\" data-kid=\"127\">\n            <div class=\"text-xs font-bold text-[#2887ff] uppercase tracking-widest\" data-kid=\"128\">Zone_09</div>\n            <div class=\"text-2xl font-bold uppercase\" data-kid=\"129\">DELHI_CORRIDOR</div>\n          </div>\n          <div class=\"absolute top-4 right-4 bg-[#2887ff] px-2 py-1 font-mono text-[10px] font-bold\" data-kid=\"130\">4.9 ★</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative overflow-hidden bg-white py-40 text-center\" data-kid=\"131\">\n    <div class=\"pointer-events-none absolute inset-0 z-0 grid-overlay opacity-20\" data-kid=\"132\"></div>\n    <div class=\"relative z-10\" data-kid=\"133\">\n      <h2 class=\"font-space outline-text mb-12 text-[15vw] font-black leading-none tracking-tighter uppercase opacity-20 md:text-[20vw]\" data-kid=\"134\">\n        READY?\n      </h2>\n      <div class=\"mx-auto max-w-xl px-6\" data-kid=\"135\">\n        <p class=\"font-space mb-10 text-xl font-medium text-[#0f172a]\" data-kid=\"136\">\n          Join the future of terrestrial travel. High-speed, high-efficiency, zero-friction booking.\n        </p>\n        <button class=\"bg-[#2887ff] px-12 py-6 font-space text-2xl font-black text-white transition-all hover:scale-105 active:scale-95\" data-kid=\"137\">\n          INITIALIZE BOOKING_v4.0\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"border-t-2 border-[#0f172a] bg-white px-6 py-20\" data-kid=\"138\">\n    <div class=\"mx-auto max-w-7xl\" data-kid=\"139\">\n      <div class=\"grid grid-cols-1 items-start gap-12 md:grid-cols-4\" data-kid=\"140\">\n        <div class=\"md:col-span-2\" data-kid=\"141\">\n          <div class=\"mb-6 flex items-center gap-2\" data-kid=\"142\">\n            <div class=\"h-6 w-6 bg-[#2887ff]\" data-kid=\"143\"></div>\n            <span class=\"font-space text-xl font-bold tracking-tighter uppercase\" data-kid=\"144\">ZigZagBus</span>\n          </div>\n          <p class=\"max-w-sm font-mono text-xs leading-relaxed text-[#0f172a]/50\" data-kid=\"145\">\n            A utilitarian approach to modern transit. System Status: Nominal. Network Health: 99.9%. Operational across 142 cities and counting.\n          </p>\n        </div>\n        <div data-kid=\"146\">\n          <h4 class=\"font-mono mb-6 text-[10px] font-bold text-[#0f172a]/40 uppercase tracking-[0.2em]\" data-kid=\"147\">Network</h4>\n          <ul class=\"font-space flex flex-col gap-3 text-sm font-medium\" data-kid=\"148\">\n            <li data-kid=\"149\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"150\">NODE_LIST</a></li>\n            <li data-kid=\"151\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"152\">ROUTE_MAP</a></li>\n            <li data-kid=\"153\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"154\">LATENCY_STATS</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"155\">\n          <h4 class=\"font-mono mb-6 text-[10px] font-bold text-[#0f172a]/40 uppercase tracking-[0.2em]\" data-kid=\"156\">Protocols</h4>\n          <ul class=\"font-space flex flex-col gap-3 text-sm font-medium\" data-kid=\"157\">\n            <li data-kid=\"158\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"159\">TERMS_OF_SVC</a></li>\n            <li data-kid=\"160\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"161\">PRIVACY_SEC</a></li>\n            <li data-kid=\"162\"><a href=\"#\" class=\"hover:text-[#2887ff]\" data-kid=\"163\">LEGAL_REPO</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"mt-20 border-t border-[#0f172a]/10 pt-10 text-center\" data-kid=\"164\">\n        <span class=\"font-mono text-[10px] text-[#0f172a]/30 uppercase\" data-kid=\"165\">© 2026 ZIGZAG_TRANSIT_SYSTEMS_LLC // ALL_RIGHTS_RESERVED</span>\n      </div>\n    </div>\n  </footer>\n</div>\n\n<style data-kid=\"166\">\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    animation: marquee 30s linear infinite;\n  }\n</style>",

      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --primary: #2887ff;\n    --midnight: #0a1128;\n    --ice: #e6f0ff;\n    --platinum: #f4f4f5;\n  }\n\n  .font-syne { font-family: 'Syne', sans-serif; }\n  .font-inter { font-family: 'Inter', sans-serif; }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(12px);\n    -webkit-backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .text-glow {\n    text-shadow: 0 0 20px rgba(40, 135, 255, 0.5);\n  }\n\n  .blob-mask {\n    mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/acid-blob.svg');\n    mask-size: contain;\n    mask-repeat: no-repeat;\n    mask-position: center;\n    -webkit-mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/acid-blob.svg');\n    -webkit-mask-size: contain;\n    -webkit-mask-repeat: no-repeat;\n    -webkit-mask-position: center;\n  }\n\n  .wave-cutoff {\n    clip-path: polygon(0 0, 100% 0, 100% 85%, 0% 100%);\n  }\n\n  .dest-card-wave {\n    clip-path: ellipse(120% 100% at 50% 100%);\n  }\n\n  /* Custom scrollbar for destinations */\n  .no-scrollbar::-webkit-scrollbar { display: none; }\n  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }\n</style>\n\n<div class=\"font-inter bg-white text-slate-900\" data-kid=\"1\">\n  \n  <section class=\"relative min-h-screen bg-[var(--midnight)] overflow-hidden flex items-center\" data-kid=\"2\">\n    \n    <div class=\"absolute top-0 right-0 w-1/2 h-full bg-[var(--primary)]/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/4\" data-kid=\"3\"></div>\n    <div class=\"absolute bottom-0 left-0 w-1/3 h-1/2 bg-[var(--primary)]/5 blur-[100px] rounded-full translate-y-1/4 -translate-x-1/4\" data-kid=\"4\"></div>\n\n    <div class=\"container mx-auto px-8 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\" data-kid=\"5\">\n      \n      <div class=\"space-y-8\" data-kid=\"6\">\n        <div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm\" data-kid=\"7\">\n          <span class=\"w-2 h-2 rounded-full bg-[var(--primary)] animate-pulse\" data-kid=\"8\"></span>\n          Premium Long Distance Travel\n        </div>\n        \n        <h1 class=\"font-syne text-7xl font-extrabold text-white leading-[1.1] text-glow\" data-kid=\"9\">\n          Redefining the <br data-kid=\"10\">\n          <span class=\"text-[var(--primary)]\" data-kid=\"11\">Modern Journey.</span>\n        </h1>\n        \n        <p class=\"text-white/60 text-lg max-w-lg leading-relaxed\" data-kid=\"12\">\n          Experience the pinnacle of high-speed transit with ZigZagBus. Aerodynamic comfort, punctual schedules, and premium service at your fingertips.\n        </p>\n\n        \n        <div class=\"glass p-8 rounded-3xl shadow-2xl space-y-6\" data-kid=\"13\">\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"14\">\n            <div class=\"space-y-2\" data-kid=\"15\">\n              <label class=\"text-xs font-semibold text-white/40 uppercase tracking-wider ml-1\" data-kid=\"16\">From</label>\n              <div class=\"relative\" data-kid=\"17\">\n                <i class=\"ti ti-map-pin absolute left-4 top-1/2 -translate-y-1/2 text-[var(--primary)]\" data-kid=\"18\"></i>\n                <input type=\"text\" placeholder=\"Enter City\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-[var(--primary)]/50 transition-colors\" data-kid=\"19\">\n              </div>\n            </div>\n            <div class=\"space-y-2\" data-kid=\"20\">\n              <label class=\"text-xs font-semibold text-white/40 uppercase tracking-wider ml-1\" data-kid=\"21\">To</label>\n              <div class=\"relative\" data-kid=\"22\">\n                <i class=\"ti ti-map-pin-filled absolute left-4 top-1/2 -translate-y-1/2 text-[var(--primary)]\" data-kid=\"23\"></i>\n                <input type=\"text\" placeholder=\"Enter Destination\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-[var(--primary)]/50 transition-colors\" data-kid=\"24\">\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"25\">\n            <div class=\"space-y-2\" data-kid=\"26\">\n              <label class=\"text-xs font-semibold text-white/40 uppercase tracking-wider ml-1\" data-kid=\"27\">Date</label>\n              <div class=\"relative\" data-kid=\"28\">\n                <i class=\"ti ti-calendar absolute left-4 top-1/2 -translate-y-1/2 text-[var(--primary)]\" data-kid=\"29\"></i>\n                <input type=\"date\" class=\"w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:outline-none focus:border-[var(--primary)]/50 transition-colors\" data-kid=\"30\">\n              </div>\n            </div>\n            <div class=\"flex items-end\" data-kid=\"31\">\n              <button class=\"w-full bg-[var(--primary)] hover:bg-[#2476da] text-white font-bold py-4 rounded-2xl transition-all shadow-lg shadow-blue-500/20 active:scale-[0.98]\" data-kid=\"32\">\n                Search Routes\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative hidden lg:block\" data-kid=\"33\">\n        <div class=\"absolute inset-0 bg-gradient-to-tr from-[var(--primary)]/20 to-transparent blur-[60px] -z-10 animate-pulse\" data-kid=\"34\"></div>\n        <div class=\"relative w-full aspect-square blob-mask overflow-hidden group\" data-kid=\"35\">\n          <img src=\"https://images.unsplash.com/photo-1616388969587-8196f32388b4?auto=format&w=1200&q=80&fit=crop\" alt=\"Modern luxury coach bus\" class=\"w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"36\">\n        </div>\n        \n        <div class=\"absolute -bottom-8 -left-8 glass p-6 rounded-2xl shadow-xl animate-bounce-slow\" data-kid=\"37\">\n          <div class=\"flex items-center gap-4\" data-kid=\"38\">\n            <div class=\"w-12 h-12 rounded-full bg-[var(--primary)]/20 flex items-center justify-center text-[var(--primary)]\" data-kid=\"39\">\n              <i class=\"ti ti-shield-check text-2xl\" data-kid=\"40\"></i>\n            </div>\n            <div data-kid=\"41\">\n              <p class=\"text-white text-sm font-bold\" data-kid=\"42\">100% Secure</p>\n              <p class=\"text-white/40 text-xs\" data-kid=\"43\">Verified Bookings</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div class=\"container mx-auto px-8 relative -mt-16 z-20\" data-kid=\"44\">\n    <div class=\"bg-white rounded-[40px] shadow-2xl shadow-black/5 p-10 flex flex-wrap lg:flex-nowrap justify-around items-center gap-8 border border-slate-100\" data-kid=\"45\">\n      <div class=\"text-center px-8 lg:border-r border-slate-100 last:border-0 flex-1 min-w-[200px]\" data-kid=\"46\">\n        <h3 class=\"font-syne text-4xl font-bold text-[var(--primary)] mb-1\" data-kid=\"47\">500+</h3>\n        <p class=\"text-slate-400 text-sm font-medium uppercase tracking-widest\" data-kid=\"48\">Active Routes</p>\n      </div>\n      <div class=\"text-center px-8 lg:border-r border-slate-100 last:border-0 flex-1 min-w-[200px]\" data-kid=\"49\">\n        <h3 class=\"font-syne text-4xl font-bold text-[var(--primary)] mb-1\" data-kid=\"50\">1.2M</h3>\n        <p class=\"text-slate-400 text-sm font-medium uppercase tracking-widest\" data-kid=\"51\">Happy Travelers</p>\n      </div>\n      <div class=\"text-center px-8 lg:border-r border-slate-100 last:border-0 flex-1 min-w-[200px]\" data-kid=\"52\">\n        <h3 class=\"font-syne text-4xl font-bold text-[var(--primary)] mb-1\" data-kid=\"53\">98%</h3>\n        <p class=\"text-slate-400 text-sm font-medium uppercase tracking-widest\" data-kid=\"54\">On-Time Rate</p>\n      </div>\n      <div class=\"text-center px-8 last:border-0 flex-1 min-w-[200px]\" data-kid=\"55\">\n        <h3 class=\"font-syne text-4xl font-bold text-[var(--primary)] mb-1\" data-kid=\"56\">4.9/5</h3>\n        <p class=\"text-slate-400 text-sm font-medium uppercase tracking-widest\" data-kid=\"57\">User Rating</p>\n      </div>\n    </div>\n  </div>\n\n  \n  <section class=\"py-32 bg-white overflow-hidden\" data-kid=\"58\">\n    <div class=\"container mx-auto px-8\" data-kid=\"59\">\n      <div class=\"mb-16 text-center lg:text-left\" data-kid=\"60\">\n        <h2 class=\"font-syne text-5xl font-extrabold text-[var(--midnight)] mb-4\" data-kid=\"61\">The Premium <span class=\"text-[var(--primary)]\" data-kid=\"62\">Standard.</span></h2>\n        <p class=\"text-slate-400 max-w-lg\" data-kid=\"63\">Everything we do is designed to make your travel as seamless as the vehicles we operate.</p>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" data-kid=\"64\">\n        \n        <div class=\"lg:col-span-2 bg-[var(--ice)]/50 rounded-[40px] p-12 relative overflow-hidden group\" data-kid=\"65\">\n          <div class=\"relative z-10 max-w-md\" data-kid=\"66\">\n            <div class=\"w-16 h-16 rounded-2xl bg-white shadow-sm flex items-center justify-center text-[var(--primary)] mb-8\" data-kid=\"67\">\n              <i class=\"ti ti-armchair text-3xl\" data-kid=\"68\"></i>\n            </div>\n            <h4 class=\"font-syne text-3xl font-bold text-[var(--midnight)] mb-4\" data-kid=\"69\">First-Class Comfort</h4>\n            <p class=\"text-slate-600 leading-relaxed mb-8\" data-kid=\"70\">Ergonomic seating with adjustable recliners, ample legroom, and personal climate control for every passenger.</p>\n            <a href=\"#\" class=\"inline-flex items-center gap-2 text-[var(--primary)] font-bold group-hover:gap-4 transition-all\" data-kid=\"71\">\n              Learn more <i class=\"ti ti-arrow-right\" data-kid=\"72\"></i>\n            </a>\n          </div>\n          <div class=\"absolute -right-20 -bottom-20 w-80 h-80 bg-[var(--primary)]/5 rounded-full blur-[60px] group-hover:bg-[var(--primary)]/10 transition-colors\" data-kid=\"73\"></div>\n        </div>\n\n        \n        <div class=\"bg-slate-50 rounded-[40px] p-10 border border-slate-100 flex flex-col items-start hover:shadow-xl transition-shadow\" data-kid=\"74\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--primary)]/10 flex items-center justify-center text-[var(--primary)] mb-8\" data-kid=\"75\">\n            <i class=\"ti ti-ticket text-2xl\" data-kid=\"76\"></i>\n          </div>\n          <h4 class=\"font-syne text-2xl font-bold text-[var(--midnight)] mb-4\" data-kid=\"77\">E-Ticket System</h4>\n          <p class=\"text-slate-500 text-sm leading-relaxed\" data-kid=\"78\">No more paper. Your smartphone is your ticket. Fast boarding via QR scanning at every terminal.</p>\n        </div>\n\n        \n        <div class=\"bg-slate-50 rounded-[40px] p-10 border border-slate-100 flex flex-col items-start hover:shadow-xl transition-shadow\" data-kid=\"79\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[var(--primary)]/10 flex items-center justify-center text-[var(--primary)] mb-8\" data-kid=\"80\">\n            <i class=\"ti ti-shield-check text-2xl\" data-kid=\"81\"></i>\n          </div>\n          <h4 class=\"font-syne text-2xl font-bold text-[var(--midnight)] mb-4\" data-kid=\"82\">Safety First</h4>\n          <p class=\"text-slate-500 text-sm leading-relaxed\" data-kid=\"83\">Advanced safety systems, real-time GPS tracking, and highly trained captains for a secure journey.</p>\n        </div>\n\n        \n        <div class=\"lg:col-span-2 bg-[var(--midnight)] rounded-[40px] p-12 relative overflow-hidden\" data-kid=\"84\">\n          <div class=\"relative z-10 text-white flex flex-col h-full justify-between\" data-kid=\"85\">\n            <div data-kid=\"86\">\n              <div class=\"w-16 h-16 rounded-2xl bg-white/10 flex items-center justify-center text-[var(--primary)] mb-8\" data-kid=\"87\">\n                <i class=\"ti ti-wallet text-3xl\" data-kid=\"88\"></i>\n              </div>\n              <h4 class=\"font-syne text-3xl font-bold mb-4\" data-kid=\"89\">Best Value Pricing</h4>\n              <p class=\"text-white/50 max-w-sm leading-relaxed\" data-kid=\"90\">Premium service shouldn't mean premium prices. We offer competitive rates and frequent loyalty rewards.</p>\n            </div>\n            <div class=\"mt-12 flex items-center gap-6\" data-kid=\"91\">\n              <div class=\"flex -space-x-3\" data-kid=\"92\">\n                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-[var(--midnight)]\" alt=\"User\" data-kid=\"93\">\n                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-[var(--midnight)]\" alt=\"User\" data-kid=\"94\">\n                <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-[var(--midnight)]\" alt=\"User\" data-kid=\"95\">\n              </div>\n              <span class=\"text-white/40 text-sm font-medium\" data-kid=\"96\">+15k new members this month</span>\n            </div>\n          </div>\n          <div class=\"absolute top-0 right-0 w-2/3 h-full bg-gradient-to-l from-[var(--primary)]/20 to-transparent\" data-kid=\"97\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-slate-50 overflow-hidden\" data-kid=\"98\">\n    <div class=\"container mx-auto px-8\" data-kid=\"99\">\n      <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16\" data-kid=\"100\">\n        <div class=\"max-w-xl\" data-kid=\"101\">\n          <h2 class=\"font-syne text-5xl font-extrabold text-[var(--midnight)] mb-4\" data-kid=\"102\">Popular <span class=\"text-[var(--primary)]\" data-kid=\"103\">Destinations.</span></h2>\n          <p class=\"text-slate-400\" data-kid=\"104\">Discover top-rated cities across the country, curated for the modern traveler.</p>\n        </div>\n        <div class=\"flex gap-4\" data-kid=\"105\">\n          <button class=\"w-14 h-14 rounded-full border border-slate-200 flex items-center justify-center hover:bg-white hover:border-white hover:shadow-lg transition-all text-slate-400 hover:text-[var(--primary)]\" data-kid=\"106\">\n            <i class=\"ti ti-chevron-left text-xl\" data-kid=\"107\"></i>\n          </button>\n          <button class=\"w-14 h-14 rounded-full border border-slate-200 flex items-center justify-center hover:bg-white hover:border-white hover:shadow-lg transition-all text-slate-400 hover:text-[var(--primary)]\" data-kid=\"108\">\n            <i class=\"ti ti-chevron-right text-xl\" data-kid=\"109\"></i>\n          </button>\n        </div>\n      </div>\n\n      <div class=\"flex gap-8 overflow-x-auto no-scrollbar pb-12 -mx-8 px-8\" data-kid=\"110\">\n        \n        <div class=\"min-w-[380px] group\" data-kid=\"111\">\n          <div class=\"bg-white rounded-[40px] overflow-hidden shadow-xl shadow-black/5 border border-slate-100 h-full flex flex-col\" data-kid=\"112\">\n            <div class=\"h-[280px] overflow-hidden relative\" data-kid=\"113\">\n              <img src=\"https://images.unsplash.com/photo-1690107645237-8a7ec86e44f7?auto=format&w=800&q=80&fit=crop\" alt=\"Munnar\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"114\">\n              <div class=\"absolute top-6 right-6 bg-white/90 backdrop-blur-md px-4 py-2 rounded-2xl flex items-center gap-2 font-bold text-sm\" data-kid=\"115\">\n                <i class=\"ti ti-star-filled text-yellow-400\" data-kid=\"116\"></i> 4.9\n              </div>\n            </div>\n            <div class=\"p-8 flex-1 relative\" data-kid=\"117\">\n              \n              <div class=\"absolute top-0 left-0 w-full h-12 -translate-y-[90%] bg-white dest-card-wave\" data-kid=\"118\"></div>\n              \n              <div class=\"flex justify-between items-start mb-4\" data-kid=\"119\">\n                <div data-kid=\"120\">\n                  <h5 class=\"font-syne text-2xl font-bold text-[var(--midnight)]\" data-kid=\"121\">Munnar, Kerala</h5>\n                  <p class=\"text-slate-400 text-sm flex items-center gap-1\" data-kid=\"122\"><i class=\"ti ti-clock\" data-kid=\"123\"></i> 8h Journey</p>\n                </div>\n                <div class=\"text-right\" data-kid=\"124\">\n                  <span class=\"text-xs font-bold text-slate-300 uppercase block mb-1\" data-kid=\"125\">Starts from</span>\n                  <span class=\"text-xl font-bold text-[var(--primary)]\" data-kid=\"126\">₹899</span>\n                </div>\n              </div>\n              <p class=\"text-slate-500 text-sm leading-relaxed mb-6\" data-kid=\"127\">Explore the lush green tea gardens and mist-covered hills of the South.</p>\n              <button class=\"w-full py-3 rounded-xl border-2 border-slate-100 font-bold text-slate-600 hover:bg-[var(--primary)] hover:border-[var(--primary)] hover:text-white transition-all\" data-kid=\"128\">\n                View Routes\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"min-w-[380px] group\" data-kid=\"129\">\n          <div class=\"bg-white rounded-[40px] overflow-hidden shadow-xl shadow-black/5 border border-slate-100 h-full flex flex-col\" data-kid=\"130\">\n            <div class=\"h-[280px] overflow-hidden relative\" data-kid=\"131\">\n              <img src=\"https://images.unsplash.com/photo-1642993469336-6ed19a7ade57?auto=format&w=800&q=80&fit=crop\" alt=\"Jaipur\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"132\">\n              <div class=\"absolute top-6 right-6 bg-white/90 backdrop-blur-md px-4 py-2 rounded-2xl flex items-center gap-2 font-bold text-sm\" data-kid=\"133\">\n                <i class=\"ti ti-star-filled text-yellow-400\" data-kid=\"134\"></i> 4.8\n              </div>\n            </div>\n            <div class=\"p-8 flex-1 relative\" data-kid=\"135\">\n              <div class=\"absolute top-0 left-0 w-full h-12 -translate-y-[90%] bg-white dest-card-wave\" data-kid=\"136\"></div>\n              <div class=\"flex justify-between items-start mb-4\" data-kid=\"137\">\n                <div data-kid=\"138\">\n                  <h5 class=\"font-syne text-2xl font-bold text-[var(--midnight)]\" data-kid=\"139\">Jaipur, Rajasthan</h5>\n                  <p class=\"text-slate-400 text-sm flex items-center gap-1\" data-kid=\"140\"><i class=\"ti ti-clock\" data-kid=\"141\"></i> 5h Journey</p>\n                </div>\n                <div class=\"text-right\" data-kid=\"142\">\n                  <span class=\"text-xs font-bold text-slate-300 uppercase block mb-1\" data-kid=\"143\">Starts from</span>\n                  <span class=\"text-xl font-bold text-[var(--primary)]\" data-kid=\"144\">₹650</span>\n                </div>\n              </div>\n              <p class=\"text-slate-500 text-sm leading-relaxed mb-6\" data-kid=\"145\">Experience the royal heritage and vibrant nighttime streets of the Pink City.</p>\n              <button class=\"w-full py-3 rounded-xl border-2 border-slate-100 font-bold text-slate-600 hover:bg-[var(--primary)] hover:border-[var(--primary)] hover:text-white transition-all\" data-kid=\"146\">\n                View Routes\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"min-w-[380px] group\" data-kid=\"147\">\n          <div class=\"bg-white rounded-[40px] overflow-hidden shadow-xl shadow-black/5 border border-slate-100 h-full flex flex-col\" data-kid=\"148\">\n            <div class=\"h-[280px] overflow-hidden relative\" data-kid=\"149\">\n              <img src=\"https://images.unsplash.com/photo-1642922835816-e2ac68db5c42?auto=format&w=800&q=80&fit=crop\" alt=\"Goa\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"150\">\n              <div class=\"absolute top-6 right-6 bg-white/90 backdrop-blur-md px-4 py-2 rounded-2xl flex items-center gap-2 font-bold text-sm\" data-kid=\"151\">\n                <i class=\"ti ti-star-filled text-yellow-400\" data-kid=\"152\"></i> 5.0\n              </div>\n            </div>\n            <div class=\"p-8 flex-1 relative\" data-kid=\"153\">\n              <div class=\"absolute top-0 left-0 w-full h-12 -translate-y-[90%] bg-white dest-card-wave\" data-kid=\"154\"></div>\n              <div class=\"flex justify-between items-start mb-4\" data-kid=\"155\">\n                <div data-kid=\"156\">\n                  <h5 class=\"font-syne text-2xl font-bold text-[var(--midnight)]\" data-kid=\"157\">Calangute, Goa</h5>\n                  <p class=\"text-slate-400 text-sm flex items-center gap-1\" data-kid=\"158\"><i class=\"ti ti-clock\" data-kid=\"159\"></i> 12h Journey</p>\n                </div>\n                <div class=\"text-right\" data-kid=\"160\">\n                  <span class=\"text-xs font-bold text-slate-300 uppercase block mb-1\" data-kid=\"161\">Starts from</span>\n                  <span class=\"text-xl font-bold text-[var(--primary)]\" data-kid=\"162\">₹1200</span>\n                </div>\n              </div>\n              <p class=\"text-slate-500 text-sm leading-relaxed mb-6\" data-kid=\"163\">Chase sunsets and coastal vibes on the beautiful beaches of Goa.</p>\n              <button class=\"w-full py-3 rounded-xl border-2 border-slate-100 font-bold text-slate-600 hover:bg-[var(--primary)] hover:border-[var(--primary)] hover:text-white transition-all\" data-kid=\"164\">\n                View Routes\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"container mx-auto px-8 pb-32\" data-kid=\"165\">\n    <div class=\"relative rounded-[60px] bg-gradient-to-r from-[var(--midnight)] to-[var(--primary)] p-20 overflow-hidden text-center\" data-kid=\"166\">\n      \n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/concentric-crescents.svg\" class=\"absolute top-10 left-10 w-40 h-40 opacity-10 blur-sm animate-pulse\" style=\"color: white;\" data-kid=\"167\">\n      <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/waves.svg\" class=\"absolute bottom-10 right-10 w-60 h-60 opacity-5\" style=\"color: white;\" data-kid=\"168\">\n      \n      <div class=\"relative z-10 space-y-8\" data-kid=\"169\">\n        <h2 class=\"font-syne text-6xl font-extrabold text-white leading-tight\" data-kid=\"170\">Ready for Your Next <br data-kid=\"171\"> <span class=\"text-[var(--ice)] text-glow\" data-kid=\"172\">Big Adventure?</span></h2>\n        <p class=\"text-white/60 max-w-2xl mx-auto text-lg\" data-kid=\"173\">Join millions of travelers who trust ZigZagBus for their premium journeys. Fast, safe, and incredibly comfortable.</p>\n        <div class=\"flex flex-col sm:flex-row gap-4 justify-center pt-4\" data-kid=\"174\">\n          <button class=\"bg-white text-[var(--midnight)] font-bold px-10 py-5 rounded-3xl hover:shadow-2xl hover:shadow-white/20 transition-all active:scale-95\" data-kid=\"175\">\n            Book Now\n          </button>\n          <button class=\"bg-white/10 text-white border border-white/20 font-bold px-10 py-5 rounded-3xl backdrop-blur-md hover:bg-white/20 transition-all\" data-kid=\"176\">\n            Download App\n          </button>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <footer class=\"py-16 border-t border-slate-100\" data-kid=\"177\">\n    <div class=\"container mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"178\">\n      <div class=\"flex items-center gap-3\" data-kid=\"179\">\n        <div class=\"w-10 h-10 bg-[var(--primary)] rounded-xl flex items-center justify-center text-white text-xl\" data-kid=\"180\">\n          <i class=\"ti ti-bus\" data-kid=\"181\"></i>\n        </div>\n        <span class=\"font-syne text-2xl font-extrabold text-[var(--midnight)]\" data-kid=\"182\">ZigZagBus</span>\n      </div>\n      <div class=\"flex gap-8 text-slate-400 font-medium text-sm\" data-kid=\"183\">\n        <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"184\">Privacy</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"185\">Terms</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"186\">Contact</a>\n        <a href=\"#\" class=\"hover:text-[var(--primary)] transition-colors\" data-kid=\"187\">FAQ</a>\n      </div>\n      <div class=\"flex gap-4\" data-kid=\"188\">\n        <a href=\"#\" class=\"w-10 h-10 rounded-full border border-slate-100 flex items-center justify-center text-slate-400 hover:text-[var(--primary)] hover:border-[var(--primary)] transition-all\" data-kid=\"189\">\n          <i class=\"ti ti-brand-twitter\" data-kid=\"190\"></i>\n        </a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full border border-slate-100 flex items-center justify-center text-slate-400 hover:text-[var(--primary)] hover:border-[var(--primary)] transition-all\" data-kid=\"191\">\n          <i class=\"ti ti-brand-instagram\" data-kid=\"192\"></i>\n        </a>\n      </div>\n    </div>\n    <div class=\"container mx-auto px-8 mt-12 text-center\" data-kid=\"193\">\n      <p class=\"text-slate-300 text-xs\" data-kid=\"194\">© 2026 ZigZagBus. All rights reserved. Premium Transit Solutions.</p>\n    </div>\n  </footer>\n</div>",

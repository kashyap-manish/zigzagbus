      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=DM+Sans:wght@400;500&display=swap');\n\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n  .font-body { font-family: 'DM Sans', sans-serif; }\n\n  .zigzag-edge {\n    clip-path: polygon(0 0, 100% 0, 100% 90%, 95% 100%, 90% 90%, 85% 100%, 80% 90%, 75% 100%, 70% 90%, 65% 100%, 60% 90%, 55% 100%, 50% 90%, 45% 100%, 40% 90%, 35% 100%, 30% 90%, 25% 100%, 20% 90%, 15% 100%, 10% 90%, 5% 100%, 0 90%);\n  }\n\n  .ticket-stub-mask {\n    background-color: white;\n    mask-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ticket.svg');\n    mask-size: contain;\n    mask-repeat: no-repeat;\n    mask-position: center;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    display: flex;\n    white-space: nowrap;\n    animation: marquee 20s linear infinite;\n  }\n\n  .brutal-shadow {\n    box-shadow: 12px 12px 0px 0px #1a1a1a;\n  }\n  .brutal-shadow-sm {\n    box-shadow: 6px 6px 0px 0px #1a1a1a;\n  }\n</style>\n\n<div class=\"font-body text-[#1a1a1a] bg-[#fcfcfc] overflow-hidden\" data-kid=\"1\">\n  \n  <nav class=\"flex items-center justify-between px-10 py-6 absolute top-0 w-full z-50\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-10 h-10 bg-[#ffc82c] rounded-lg flex items-center justify-center border-2 border-[#1a1a1a] brutal-shadow-sm\" data-kid=\"4\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bus.svg\" class=\"w-6 h-6\" alt=\"Logo\" data-kid=\"5\">\n      </div>\n      <span class=\"font-heading text-2xl font-extrabold text-white tracking-tight drop-shadow-md\" data-kid=\"6\">zigzagbus</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 font-medium text-white\" data-kid=\"7\">\n      <a href=\"#\" class=\"hover:text-[#ffc82c] transition-colors\" data-kid=\"8\">Offers</a>\n      <a href=\"#\" class=\"hover:text-[#ffc82c] transition-colors\" data-kid=\"9\">My Bookings</a>\n      <a href=\"#\" class=\"hover:text-[#ffc82c] transition-colors\" data-kid=\"10\">Support</a>\n      <button class=\"bg-[#ffc82c] text-[#1a1a1a] px-6 py-2 rounded-full font-bold border-2 border-[#1a1a1a] brutal-shadow-sm hover:translate-y-1 hover:shadow-none transition-all\" data-kid=\"11\">Login</button>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative bg-[#2887ff] pt-40 pb-48 zigzag-edge overflow-hidden\" data-kid=\"12\">\n    \n    <div class=\"absolute inset-0 opacity-10\" style=\"background-image: url('https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/checkered-diamond.svg'); background-size: 100px;\" data-kid=\"13\"></div>\n    \n    <div class=\"container mx-auto px-6 text-center relative z-10\" data-kid=\"14\">\n      <h1 class=\"font-heading text-6xl md:text-8xl font-black text-white leading-tight mb-8\" data-kid=\"15\">\n        Travel that <br data-kid=\"16\">\n        <span class=\"text-[#ffc82c] italic\" data-kid=\"17\">Feels Magical!</span>\n      </h1>\n      \n      \n      <div class=\"max-w-4xl mx-auto bg-white p-8 rounded-2xl border-4 border-[#1a1a1a] brutal-shadow relative\" data-kid=\"18\">\n        \n        <div class=\"absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-12 bg-[#2887ff] rounded-full border-2 border-[#1a1a1a]\" data-kid=\"19\"></div>\n        <div class=\"absolute -right-3 top-1/2 -translate-y-1/2 w-6 h-12 bg-[#2887ff] rounded-full border-2 border-[#1a1a1a]\" data-kid=\"20\"></div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"21\">\n          <div class=\"text-left\" data-kid=\"22\">\n            <label class=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\" data-kid=\"23\">From</label>\n            <input type=\"text\" placeholder=\"Origin City\" class=\"w-full text-lg font-bold border-b-2 border-gray-100 focus:border-[#2887ff] outline-none pb-2\" data-kid=\"24\">\n          </div>\n          <div class=\"text-left\" data-kid=\"25\">\n            <label class=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\" data-kid=\"26\">To</label>\n            <input type=\"text\" placeholder=\"Destination\" class=\"w-full text-lg font-bold border-b-2 border-gray-100 focus:border-[#2887ff] outline-none pb-2\" data-kid=\"27\">\n          </div>\n          <div class=\"text-left\" data-kid=\"28\">\n            <label class=\"block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2\" data-kid=\"29\">Date</label>\n            <input type=\"date\" class=\"w-full text-lg font-bold border-b-2 border-gray-100 focus:border-[#2887ff] outline-none pb-2\" data-kid=\"30\">\n          </div>\n          <div class=\"flex items-end\" data-kid=\"31\">\n            <button class=\"w-full bg-[#2887ff] text-white py-4 rounded-xl font-heading text-xl font-bold border-2 border-[#1a1a1a] brutal-shadow-sm hover:translate-y-1 hover:shadow-none transition-all\" data-kid=\"32\">Search Bus</button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[#fff0e6] py-20 relative\" data-kid=\"33\">\n    <div class=\"container mx-auto px-6 relative\" data-kid=\"34\">\n      \n      <div class=\"absolute -top-32 left-1/4 rotate-[-5deg] bg-white p-4 rounded-full border-2 border-[#1a1a1a] brutal-shadow-sm flex items-center gap-3 z-20\" data-kid=\"35\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/bus.svg\" class=\"w-8 h-8\" alt=\"Bus\" data-kid=\"36\">\n        <div data-kid=\"37\">\n          <p class=\"font-heading text-xl font-black\" data-kid=\"38\">2000+</p>\n          <p class=\"text-xs font-bold uppercase\" data-kid=\"39\">Buses Daily</p>\n        </div>\n      </div>\n\n      <div class=\"absolute -top-40 right-1/4 rotate-[3deg] bg-[#ffc82c] p-6 rounded-2xl border-2 border-[#1a1a1a] brutal-shadow-sm flex flex-col items-center z-20\" data-kid=\"40\">\n        <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/star.svg\" class=\"w-10 h-10 mb-2\" alt=\"Star\" data-kid=\"41\">\n        <p class=\"font-heading text-2xl font-black\" data-kid=\"42\">4.8/5</p>\n        <p class=\"text-xs font-bold uppercase text-center\" data-kid=\"43\">User Rating</p>\n      </div>\n\n      <div class=\"text-center mt-20\" data-kid=\"44\">\n        <h2 class=\"font-heading text-4xl font-black mb-4\" data-kid=\"45\">Why choose the ZigZag way?</h2>\n        <p class=\"text-xl max-w-2xl mx-auto text-gray-600\" data-kid=\"46\">We turned the boring commute into a vibrant adventure. Reliable, fun, and lightning fast.</p>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-32 bg-white relative\" data-kid=\"47\">\n    <div class=\"container mx-auto px-6 max-w-5xl relative\" data-kid=\"48\">\n      \n      <div class=\"absolute left-1/2 top-0 bottom-0 w-1 border-l-4 border-dashed border-[#2887ff] -translate-x-1/2 hidden md:block\" data-kid=\"49\"></div>\n\n      \n      <div class=\"flex flex-col md:flex-row items-center gap-10 mb-24 relative\" data-kid=\"50\">\n        <div class=\"md:w-1/2 md:text-right\" data-kid=\"51\">\n          <div class=\"bg-[#e6f0ff] p-8 rounded-2xl border-4 border-[#1a1a1a] brutal-shadow md:ml-auto max-w-sm\" data-kid=\"52\">\n            <div class=\"w-16 h-16 bg-[#ffc82c] rounded-full flex items-center justify-center border-2 border-[#1a1a1a] mb-4 md:ml-auto\" data-kid=\"53\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/ticket.svg\" class=\"w-10 h-10\" alt=\"Ticket\" data-kid=\"54\">\n            </div>\n            <h3 class=\"font-heading text-2xl font-black mb-2\" data-kid=\"55\">Easy Booking</h3>\n            <p class=\"font-medium text-gray-600\" data-kid=\"56\">Book your tickets in under 60 seconds with our optimized flow.</p>\n          </div>\n        </div>\n        <div class=\"w-10 h-10 bg-[#2887ff] rounded-full border-4 border-white shadow-md z-10 hidden md:block\" data-kid=\"57\"></div>\n        <div class=\"md:w-1/2\" data-kid=\"58\"></div>\n      </div>\n\n      \n      <div class=\"flex flex-col md:flex-row-reverse items-center gap-10 mb-24 relative\" data-kid=\"59\">\n        <div class=\"md:w-1/2\" data-kid=\"60\">\n          <div class=\"bg-[#fff0e6] p-8 rounded-2xl border-4 border-[#1a1a1a] brutal-shadow max-w-sm\" data-kid=\"61\">\n            <div class=\"w-16 h-16 bg-[#ffc82c] rounded-full flex items-center justify-center border-2 border-[#1a1a1a] mb-4\" data-kid=\"62\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/armchair.svg\" class=\"w-10 h-10\" alt=\"Seat\" data-kid=\"63\">\n            </div>\n            <h3 class=\"font-heading text-2xl font-black mb-2\" data-kid=\"64\">Pick Your Spot</h3>\n            <p class=\"font-medium text-gray-600\" data-kid=\"65\">Choose your favorite seat with our interactive 3D bus maps.</p>\n          </div>\n        </div>\n        <div class=\"w-10 h-10 bg-[#2887ff] rounded-full border-4 border-white shadow-md z-10 hidden md:block\" data-kid=\"66\"></div>\n        <div class=\"md:w-1/2\" data-kid=\"67\"></div>\n      </div>\n\n      \n      <div class=\"flex flex-col md:flex-row items-center gap-10 mb-24 relative\" data-kid=\"68\">\n        <div class=\"md:w-1/2 md:text-right\" data-kid=\"69\">\n          <div class=\"bg-[#e6f0ff] p-8 rounded-2xl border-4 border-[#1a1a1a] brutal-shadow md:ml-auto max-w-sm\" data-kid=\"70\">\n            <div class=\"w-16 h-16 bg-[#ffc82c] rounded-full flex items-center justify-center border-2 border-[#1a1a1a] mb-4 md:ml-auto\" data-kid=\"71\">\n              <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/shield.svg\" class=\"w-10 h-10\" alt=\"Shield\" data-kid=\"72\">\n            </div>\n            <h3 class=\"font-heading text-2xl fon